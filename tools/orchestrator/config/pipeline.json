{
  "default_task_description": "Review the current CuedUp repository state, identify the most important implementation risks, and suggest the next practical developer actions.",
  "prompts": {
    "system_template": "prompts/system/base.md",
    "task_template": "prompts/tasks/repo-review.md"
  },
  "adapters": [
    {
      "name": "codex",
      "provider": "codex",
      "model": "codex",
      "cli_command": "codex"
    },
    {
      "name": "claude-sonnet-4-6",
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "max_tokens": 2048
    },
    {
      "name": "gpt-4o",
      "provider": "openai",
      "model": "gpt-4o"
    },
    {
      "name": "gemini-2.5-pro",
      "provider": "gemini",
      "model": "gemini-2.5-pro"
    }
  ]
}
